{
  "name": "sniffler",
  "version": "0.3.0",
  "description": "Sniffler sniffs out the E2E tests your changes actually wake up.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callstackincubator/sniffler.git"
  },
  "bugs": {
    "url": "https://github.com/callstackincubator/sniffler/issues"
  },
  "homepage": "https://github.com/callstackincubator/sniffler#readme",
  "keywords": [
    "cli",
    "e2e",
    "impact-analysis",
    "javascript",
    "monorepo",
    "react-native",
    "sniffler",
    "typescript",
    "vitest"
  ],
  "author": "Callstack Incubator",
  "bin": {
    "sniffler": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --config vitest.config.ts",
    "benchmark": "vitest bench --config vitest.config.ts tests/benchmark.bench.ts",
    "benchmark:app": "node scripts/benchmark-expensify-app.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "packageManager": "pnpm@11.5.1",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "fast-glob": "^3.3.3",
    "picomatch": "^4.0.4"
  }
}
